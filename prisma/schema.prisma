generator client {
  provider = "prisma-client-js"
  output   = "./__generated__"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AppointmentStatus {
  PENDING_VERIFICATION
  PENDING
  CONFIRMED
  DECLINED
  RESCHEDULED
  COMPLETED
  CLIENT_NO_SHOW
  NOT_COMPLETED
  CANCELLED
}

enum CancelledBy {
  CLIENT
  COMPANY
}

model Appointment {
  id                 String  @id @default(uuid())
  appointmentNumber  String  @unique
  userId             String?
  serviceId          String?
  serviceVariationId String?
  specialistId       String?
  branchId           String
  organizationId     String

  name            String
  clientPhone     String?

  // Denormalized fields for enriched responses
  serviceName          String?
  specialistFirstName  String?
  specialistLastName   String?
  branchAddress        String?

  date            DateTime          @db.Date
  startTime       DateTime          @db.Time()
  endTime         DateTime          @db.Time()
  comment         String?
  status          AppointmentStatus @default(PENDING_VERIFICATION)
  price           Decimal?          @db.Decimal(10, 2)
  durationMinutes Int?

  companyNotes       String?
  declineReason      String?
  cancellationReason String?
  cancelledBy        CancelledBy?

  rescheduledDate      DateTime? @db.Date
  rescheduledStartTime DateTime? @db.Time()
  rescheduledEndTime   DateTime? @db.Time()
  rescheduleComment    String?

  confirmedAt   DateTime?
  declinedAt    DateTime?
  rescheduledAt DateTime?
  completedAt   DateTime?
  cancelledAt   DateTime?

  hasCustomerReview Boolean @default(false) @map("has_customer_review")

  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  statusHistory AppointmentStatusHistory[]
  verifications AppointmentVerification[]

  @@index([userId])
  @@index([branchId])
  @@index([organizationId])
  @@index([serviceId])
  @@index([specialistId])
  @@index([status])
  @@index([date])
  @@map("appointments")
}

model AppointmentStatusHistory {
  id            String             @id @default(uuid())
  appointmentId String
  fromStatus    AppointmentStatus?
  toStatus      AppointmentStatus
  changedBy     String?
  reason        String?
  metadata      Json?
  createdAt     DateTime           @default(now())

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([appointmentId])
  @@map("appointment_status_history")
}

model AppointmentVerification {
  id               String    @id @default(uuid())
  appointmentId    String
  phone            String
  verificationCode String
  expiresAt        DateTime
  isUsed           Boolean   @default(false)
  attemptsLeft     Int       @default(3)
  nextResendAt     DateTime?
  createdAt        DateTime  @default(now())

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([appointmentId])
  @@index([verificationCode])
  @@map("appointment_verifications")
}

model Service {
  id              String   @id @default(uuid())
  organizationId  String
  name            String
  description     String?
  parentServiceId String?
  typeId          String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  type               ServiceType?        @relation(fields: [typeId], references: [id])
  serviceDurations   ServiceDuration[]
  specialistServices SpecialistService[] @relation(name: "specialistServices")
  serviceLocations   ServiceLocation[]   @relation(name: "serviceLocations")

  @@index([organizationId])
  @@index([organizationId, parentServiceId])
  @@index([typeId])
  @@map("services")
}

model Location {
  id             String   @id @default(uuid())
  organizationId String
  name           String
  address        String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  schedules           Schedule[]           @relation(name: "locationSchedules")
  specialistLocations SpecialistLocation[] @relation(name: "specialistLocations")
  serviceLocations    ServiceLocation[]    @relation(name: "serviceLocations")

  @@index([organizationId])
  @@map("locations")
}

model Specialist {
  id             String   @id @default(uuid())
  organizationId String
  avatar         String?
  firstName      String
  lastName       String
  email          String
  phone          String?
  description    String?
  isTopMaster    Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  schedules           Schedule[]           @relation(name: "specialistSchedules")
  specialistServices  SpecialistService[]  @relation(name: "specialistServices")
  specialistLocations SpecialistLocation[] @relation(name: "specialistLocations")

  @@index([organizationId])
  @@index([organizationId, email])
  @@index([organizationId, isTopMaster])
  @@map("specialists")
}

model Schedule {
  id             String   @id @default(uuid())
  organizationId String
  specialistId   String
  locationId     String
  dayOfWeek      Int
  intervals      Json
  isDayOff       Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  specialist Specialist @relation(fields: [specialistId], references: [id], onDelete: Cascade, name: "specialistSchedules")
  location   Location   @relation(fields: [locationId], references: [id], onDelete: Cascade, name: "locationSchedules")

  @@unique([organizationId, specialistId, locationId, dayOfWeek])
  @@index([organizationId, specialistId, locationId])
  @@index([organizationId, locationId, dayOfWeek])
  @@map("schedules")
}

model ServiceDuration {
  id              String   @id @default(uuid())
  serviceId       String
  organizationId  String
  branchId        String?
  durationMinutes Int
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  service Service? @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([serviceId, organizationId, branchId])
  @@index([serviceId])
  @@index([organizationId])
  @@map("service_durations")
}

// Junction Tables for Many-to-Many Relationships

model SpecialistService {
  id             String   @id @default(uuid())
  organizationId String
  specialistId   String
  serviceId      String
  createdAt      DateTime @default(now())

  specialist Specialist @relation(fields: [specialistId], references: [id], onDelete: Cascade, name: "specialistServices")
  service    Service    @relation(fields: [serviceId], references: [id], onDelete: Cascade, name: "specialistServices")

  @@unique([organizationId, specialistId, serviceId])
  @@index([organizationId, specialistId, serviceId])
  @@index([organizationId, serviceId, specialistId])
  @@index([organizationId, specialistId])
  @@map("specialist_services")
}

model SpecialistLocation {
  id             String   @id @default(uuid())
  organizationId String
  specialistId   String
  locationId     String
  createdAt      DateTime @default(now())

  specialist Specialist @relation(fields: [specialistId], references: [id], onDelete: Cascade, name: "specialistLocations")
  location   Location   @relation(fields: [locationId], references: [id], onDelete: Cascade, name: "specialistLocations")

  @@unique([organizationId, specialistId, locationId])
  @@index([organizationId, specialistId, locationId])
  @@index([organizationId, locationId, specialistId])
  @@index([organizationId, specialistId])
  @@map("specialist_locations")
}

model ServiceLocation {
  id             String   @id @default(uuid())
  organizationId String
  serviceId      String
  locationId     String
  createdAt      DateTime @default(now())

  service  Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade, name: "serviceLocations")
  location Location @relation(fields: [locationId], references: [id], onDelete: Cascade, name: "serviceLocations")

  @@unique([organizationId, serviceId, locationId])
  @@index([organizationId, serviceId, locationId])
  @@index([organizationId, locationId, serviceId])
  @@index([organizationId, serviceId])
  @@map("service_locations")
}

// Service Categories and Types

enum ServiceTypeStatus {
  ACTIVE
  PENDING
  REJECTED
}

model ServiceCategory {
  id        String   @id @default(uuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  types ServiceType[]

  @@map("service_categories")
}

model ServiceType {
  id                String            @id @default(uuid())
  name              String
  slug              String            @unique
  categoryId        String
  status            ServiceTypeStatus @default(ACTIVE)
  suggestedByUserId String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  category ServiceCategory @relation(fields: [categoryId], references: [id])
  services Service[]

  @@unique([name, categoryId])
  @@index([categoryId])
  @@map("service_types")
}

// ─── Reminders ──────────────────────────────────────────

enum ReminderRepeat {
  NONE
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

model Reminder {
  id          String         @id @default(uuid())
  userId      String
  title       String
  date        DateTime       @db.Date
  time        DateTime?      @db.Time()
  comment     String?
  repeat      ReminderRepeat @default(NONE)
  isFavorite  Boolean        @default(false)
  isCompleted Boolean        @default(false)
  completedAt DateTime?

  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([userId, date])
  @@index([userId, isFavorite])
  @@index([userId, isCompleted])
  @@map("reminders")
}
