generator client {
  provider = "prisma-client-js"
  output   = "./__generated__"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AppointmentStatus {
  PENDING_VERIFICATION
  PENDING
  CONFIRMED
  DECLINED
  RESCHEDULED
  COMPLETED
  CLIENT_NO_SHOW
  NOT_COMPLETED
  CANCELLED
}

enum CancelledBy {
  CLIENT
  COMPANY
}

model Appointment {
  id                 String  @id @default(uuid())
  appointmentNumber  String  @unique
  userId             String
  serviceId          String
  serviceVariationId String?
  branchId           String
  organizationId     String

  name            String
  date            DateTime          @db.Date
  startTime       DateTime          @db.Time()
  endTime         DateTime          @db.Time()
  comment         String?
  status          AppointmentStatus @default(PENDING_VERIFICATION)
  price           Decimal?          @db.Decimal(10, 2)
  durationMinutes Int?

  companyNotes       String?
  declineReason      String?
  cancellationReason String?
  cancelledBy        CancelledBy?

  rescheduledDate      DateTime? @db.Date
  rescheduledStartTime DateTime? @db.Time()
  rescheduledEndTime   DateTime? @db.Time()
  rescheduleComment    String?

  confirmedAt   DateTime?
  declinedAt    DateTime?
  rescheduledAt DateTime?
  completedAt   DateTime?
  cancelledAt   DateTime?

  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  statusHistory AppointmentStatusHistory[]
  verifications AppointmentVerification[]

  @@index([userId])
  @@index([branchId])
  @@index([organizationId])
  @@index([serviceId])
  @@index([status])
  @@index([date])
  @@map("appointments")
}

model AppointmentStatusHistory {
  id            String             @id @default(uuid())
  appointmentId String
  fromStatus    AppointmentStatus?
  toStatus      AppointmentStatus
  changedBy     String?
  reason        String?
  metadata      Json?
  createdAt     DateTime           @default(now())

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([appointmentId])
  @@map("appointment_status_history")
}

model AppointmentVerification {
  id               String    @id @default(uuid())
  appointmentId    String
  phone            String
  verificationCode String
  expiresAt        DateTime
  isUsed           Boolean   @default(false)
  attemptsLeft     Int       @default(3)
  nextResendAt     DateTime?
  createdAt        DateTime  @default(now())

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([appointmentId])
  @@index([verificationCode])
  @@map("appointment_verifications")
}

model Service {
  id              String   @id @default(uuid())
  organizationId  String
  name            String
  description     String?
  parentServiceId String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  serviceDurations ServiceDuration[]

  @@index([organizationId])
  @@index([organizationId, parentServiceId])
  @@map("services")
}

model Location {
  id             String   @id @default(uuid())
  organizationId String
  name           String
  address        String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  schedules Schedule[]

  @@index([organizationId])
  @@map("locations")
}

model Specialist {
  id             String   @id @default(uuid())
  organizationId String
  avatar         String?
  firstName      String
  lastName       String
  email          String
  phone          String?
  description    String?
  isTopMaster    Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  schedules Schedule[]

  @@index([organizationId])
  @@index([organizationId, email])
  @@index([organizationId, isTopMaster])
  @@map("specialists")
}

model Schedule {
  id             String   @id @default(uuid())
  organizationId String
  specialistId   String
  locationId     String
  dayOfWeek      Int
  intervals      Json
  isDayOff       Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  specialist Specialist @relation(fields: [specialistId], references: [id], onDelete: Cascade)
  location   Location   @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, specialistId, locationId, dayOfWeek])
  @@index([organizationId, specialistId, locationId])
  @@index([organizationId, locationId, dayOfWeek])
  @@map("schedules")
}

model ServiceDuration {
  id              String   @id @default(uuid())
  serviceId       String
  organizationId  String
  branchId        String?
  durationMinutes Int
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  service Service? @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([serviceId, organizationId, branchId])
  @@index([serviceId])
  @@index([organizationId])
  @@map("service_durations")
}
